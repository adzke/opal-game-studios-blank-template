{
    "name": "opal-game-studios-blank-template",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "npm run dev --workspace=apps/web",
        "dev:docker": "docker compose -f docker-compose.yml -f docker-compose.debug.yml up --build",
        "build": "npm run build --workspace=apps/web",
        "server": "bun server/index.js",
        "lint": "eslint . --max-warnings=0",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.1.0",
        "pg": "^8.16.3",
        "socket.io": "^4.8.1",
        "supertokens-node": "^24.0.1"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^8.57.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-vitest": "^0.5.4",
        "jsdom": "^26.1.0",
        "supertest": "^7.1.4",
        "vitest": "^3.2.4"
    }
}
