{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:react/recommended"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module",
        "ecmaFeatures": {
            "jsx": true
        }
    },
    "settings": {
        "react": {
            "version": "detect"
        }
    },
    "globals": {
        "describe": "readonly",
        "expect": "readonly",
        "it": "readonly",
        "vi": "readonly",
        "beforeAll": "readonly",
        "beforeEach": "readonly",
        "afterAll": "readonly",
        "afterEach": "readonly"
    },
    "rules": {
        "indent": [
            "error",
            4
        ],
        "linebreak-style": [
            "error",
            "unix"
        ],
        "quotes": [
            "error",
            "single"
        ],
        "semi": [
            "error",
            "always"
        ],
        "no-unused-vars": "error",
        "complexity": [
            "error",
            10
        ],
        "max-lines": [
            "error",
            500
        ],
        "eqeqeq": [
            "error",
            "always"
        ],
        "curly": [
            "error",
            "all"
        ],
        "prefer-const": "error",
        "no-var": "error",
        "react/prop-types": "off",
        "react/react-in-jsx-scope": "off"
    },
    "overrides": [
        {
            "files": [
                "tests/**",
                "**/*.test.js",
                "**/*.test.jsx",
                "**/*.spec.js",
                "**/*.spec.jsx"
            ],
            "rules": {
                "complexity": "off",
                "max-lines": "off"
            }
        }
    ]
}
